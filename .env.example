# Modèle de configuration. Copier ce fichier en ".env" et adapter si besoin.
# Le vrai ".env" n'est PAS versionné (voir .gitignore).

# Base PostgreSQL locale (Docker). Valeurs par défaut du docker-compose.yml.
DB_PORT="5432"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/suivi_marge"

# Déploiement Neon/Vercel :
# - Dans Vercel, DATABASE_URL doit être l'URL Neon poolée
#   (hôte contenant "-pooler", avec sslmode=require).
# - Pour appliquer le schéma avec Drizzle, vous pouvez aussi définir
#   DATABASE_URL_UNPOOLED avec l'URL Neon directe. Si absente, Drizzle utilisera
#   DATABASE_URL.
# DATABASE_URL_UNPOOLED="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# Secret de signature des sessions (cookie de connexion). Obligatoire.
# Générer une valeur aléatoire longue, par exemple :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="remplacez-par-une-valeur-aleatoire-longue"
